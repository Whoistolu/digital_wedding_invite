{
  "name": "app",
  "private": true,
  "devDependencies": {
    "esbuild": "^0.27.4"
  },
  "scripts": {
    "build": "esbuild app/javascript/application.jsx --bundle --sourcemap --format=esm --outdir=app/assets/builds --public-path=/assets --loader:.jsx=jsx --loader:.js=jsx",
    "build:css": "npx @tailwindcss/cli -i ./app/assets/stylesheets/application.tailwind.css -o ./app/assets/builds/application.css --minify"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "framer-motion": "^12.38.0",
    "gsap": "^3.14.2",
    "react": "^19.2.4",
    "react-confetti": "^6.4.0",
    "react-dom": "^19.2.4",
    "react-intersection-observer": "^10.0.3",
    "react-scroll": "^1.9.3",
    "tailwindcss": "^4.2.2"
  }
}
